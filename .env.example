# =========================================================================
# 美股量化 AI 軍師 - 環境變數設定範本
# =========================================================================
# 使用說明：
# 1. 複製此檔案並重新命名為 `.env`
# 2. 將下方的金鑰替換為您個人的實際金鑰
# 3. 執行 run_quant_brain.py 時程式會自動載入此檔案

# Gemini API 金鑰 (必要)
# 申請網址: https://ai.google.dev/gemini-api/docs/api-key
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram 推播設定 (選填，若不設定則使用程式預設的測試機器人與頻道)
TG_BOT_TOKEN=your_telegram_bot_token_here
TG_CHAT_ID=your_telegram_chat_id_here
